# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
MY_DISCORD_USER_ID=your_discord_user_id_here
MY_DISCORD_USERNAME=your_discord_username_here

# Aternos Configuration
ATERNOS_TARGET_SERVER=your_server_name_here
ATERNOS_SESSION=your_optional_aternos_session_cookie_value

# Fallback Credentials (if session cookie expires or is not set)
ATERNOS_USER=your_aternos_username_or_email
ATERNOS_PASS=your_aternos_password

# Proxy Configuration (Optional)
# Format: http://username:password@ip:port
PROXY_SERVER=
# Or build from individual vars:
PROXY_USER=
PROXY_PASS=
PROXY_HOST=
PROXY_PORT=

# Proxy Rotation (Optional)
# Set to true and provide comma-separated proxies in PROXY_LIST to rotate
PROXY_ROTATION=false
PROXY_LIST=

# Headless browser mode for Aternos login (default: true)
ATERNOS_HEADLESS=true

# Anti-Detection Settings
# Max time (ms) to wait for Cloudflare challenge to resolve
ATERNOS_CF_MAX_WAIT=45
# Max login retry attempts (default: 5)
ATERNOS_MAX_RETRIES=5

# Health Check Auth (Optional)
# If set, the / endpoint requires X-Health-Token header or ?token= query param
HEALTH_SECRET=

# Self-Ping URL (Required for HuggingFace Spaces)
# Set this to your Space URL to prevent idle spin-down
# Format: https://your-username-space-name.hf.space
SELF_PING_URL=

# Gemini AI Chat (Optional)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Bot personality prompt (leave blank for default)
GEMINI_BOT_PERSONA=
# Model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Max conversation history per channel (default: 50)
GEMINI_HISTORY_LIMIT=50
